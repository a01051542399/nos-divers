# ──────────────────────────────────────────────────────────
# Dive ON — 환경 변수 템플릿
# ──────────────────────────────────────────────────────────
# 사용:
#   1) 이 파일을 .env.local 로 복사
#   2) 아래 값을 새로 만든 Supabase 프로젝트의 값으로 교체
#   3) 절대 git 에 커밋하지 말 것 (.env* 는 .gitignore 에 포함됨)
# ──────────────────────────────────────────────────────────

# Supabase 프로젝트 → Settings → API
#   "Project URL" 을 복사
VITE_SUPABASE_URL=https://YOUR-NEW-PROJECT.supabase.co

# 같은 페이지의 "anon public" 키 (Service Role 키 아님!)
VITE_SUPABASE_ANON_KEY=YOUR-NEW-ANON-KEY

# (선택) Sentry 등 추후 모니터링 키
# VITE_SENTRY_DSN=
