{
  "expo": {
    "name": "NoS Divers",
    "slug": "nos-divers",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "com.nosdivers.app",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nosdivers.app",
      "infoPlist": {
        "NSCameraUsageDescription": "영수증 촬영을 위해 카메라 접근이 필요합니다",
        "NSPhotoLibraryUsageDescription": "영수증 사진을 선택하기 위해 사진 라이브러리 접근이 필요합니다"
      }
    },
    "android": {
      "package": "com.nosdivers.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser"
    ]
  }
}
