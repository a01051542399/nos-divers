# ══════════════════════════════════════════════════════
# NoS Divers App - Environment Variables
# ══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────
DATABASE_URL=mysql://nosdivers:your-db-password@localhost:3306/nos_divers
MYSQL_ROOT_PASSWORD=your-root-password
MYSQL_PASSWORD=your-db-password

# ── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=development
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
BASE_URL=http://localhost:3000
CLIENT_URL=http://localhost:8081

# ── Google OAuth ──────────────────────────────────────
# 1. https://console.cloud.google.com 에서 프로젝트 생성
# 2. OAuth 2.0 클라이언트 ID 생성
# 3. 승인된 리디렉션 URI: http://localhost:3000/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Kakao OAuth ───────────────────────────────────────
# 1. https://developers.kakao.com 에서 애플리케이션 등록
# 2. REST API 키 복사
# 3. Redirect URI: http://localhost:3000/api/oauth/kakao/callback
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── Admin ─────────────────────────────────────────────
# Comma-separated admin email addresses
ADMIN_EMAILS=your-email@gmail.com

# ── Expo (Client) ────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
